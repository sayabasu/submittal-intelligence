generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  location    String?
  capacityMw  Float?
  owner       String?
  epc         String?

  noticeToProceedDate  DateTime?
  targetCompletionDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submittals  Submittal[]
  escalations Escalation[]
}

model Submittal {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  submittalNumber String
  specSection     String
  description     String

  equipmentCategory String
  submittalType     String @default("product_data")
  discipline        String

  status   String @default("not_submitted")
  revision Int    @default(0)

  submittedDate DateTime?
  reviewDueDate DateTime?
  approvedDate  DateTime?

  linkedPoDate               DateTime?
  manufacturingLeadTimeWeeks Int
  requiredOnSiteDate         DateTime
  shippingBufferDays         Int @default(14)
  poProcessingDays           Int @default(10)

  vendor        String
  vendorContact String?
  vendorEmail   String?
  reviewer      String
  reviewerEmail String?
  submitter     String?

  riskLevel         String?
  riskScore         Float?
  daysUntilCritical Int?
  riskCalculatedAt  DateTime?
  riskNotes         String?

  notes     String?
  sourceRow Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  escalations   Escalation[]
  statusHistory SubmittalStatusHistory[]

  @@unique([projectId, submittalNumber])
  @@index([projectId, riskLevel])
  @@index([projectId, status])
  @@index([equipmentCategory])
}

model SubmittalStatusHistory {
  id          String    @id @default(cuid())
  submittalId String
  submittal   Submittal @relation(fields: [submittalId], references: [id])

  fromStatus String?
  toStatus   String
  changedAt  DateTime @default(now())
  changedBy  String?
  notes      String?
}

model Escalation {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  submittalId String
  submittal   Submittal @relation(fields: [submittalId], references: [id])

  subject        String
  body           String
  recipient      String
  recipientEmail String?
  urgencyLevel   String

  aiModel          String?
  promptVersion    String?
  generationTimeMs Int?

  status        String    @default("draft")
  editedBody    String?
  approvedAt    DateTime?
  approvedBy    String?
  sentAt        DateTime?
  dismissedAt   DateTime?
  dismissReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
  @@index([submittalId])
}

model UploadLog {
  id            String   @id @default(cuid())
  filename      String
  fileType      String
  rowCount      Int
  importedCount Int
  skippedCount  Int
  errorCount    Int
  columnMapping String
  uploadedBy    String @default("system")
  createdAt     DateTime @default(now())
}

model LeadTimeReference {
  id                   String  @id @default(cuid())
  equipmentCategory    String  @unique
  displayName          String
  typicalLeadTimeWeeks Int
  minLeadTimeWeeks     Int
  maxLeadTimeWeeks     Int
  typicalReviewDays    Int
  notes                String?
}
